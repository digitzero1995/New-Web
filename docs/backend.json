
{
  "entities": {
    "TradingAccount": {
      "title": "Trading Account",
      "description": "Configuration for an MT5 trading terminal connection.",
      "type": "object",
      "properties": {
        "accNum": { "type": "string" },
        "broker": { "type": "string" },
        "role": { "type": "string", "enum": ["master", "follower"] },
        "status": { "type": "string" },
        "token": { "type": "string" },
        "multiplier": { "type": "number", "description": "Used by followers to scale master lots." },
        "masterId": { "type": "string", "description": "The accNum of the master this follower is linked to." }
      },
      "required": ["accNum", "broker", "role"]
    },
    "TradeSignal": {
      "title": "Trade Signal",
      "description": "A signal generated by a master account or executed by a follower.",
      "type": "object",
      "properties": {
        "masterAccNum": { "type": "string" },
        "followerAccNum": { "type": "string", "description": "Empty for master signals." },
        "symbol": { "type": "string" },
        "type": { "type": "string", "enum": ["BUY", "SELL"] },
        "lot": { "type": "number" },
        "masterLot": { "type": "number", "description": "The original lot size from the master." },
        "status": { "type": "string", "enum": ["Open", "Closed"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "profit": { "type": "number" }
      },
      "required": ["symbol", "type", "lot", "status"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/accounts/{accountId}": {
      "schema": "#/entities/TradingAccount",
      "description": "Registered MT5 terminals."
    },
    "/trades/{tradeId}": {
      "schema": "#/entities/TradeSignal",
      "description": "Log of all master signals and copied follower trades."
    }
  }
}
